# Doubao Music Generation - Environment Variable Configuration
# Copy this file to .env and fill in real values: cp .env.example .env

# Volcano Engine AccessKey ID (required)
# Obtain from Volcano Engine Console: https://console.volcengine.com/iam/keymanage/
VOLC_ACCESS_KEY=$VOLC_ACCESS_KEY

# 火山引擎 Secret Access Key（必填）
VOLC_SECRET_KEY=$VOLC_SECRET_KEY
