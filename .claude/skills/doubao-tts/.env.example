# Doubao TTS - Environment Variable Configuration
# Copy this file to .env and fill in your actual values: cp .env.example .env

# -- New Console (recommended, only DOUBAO_API_KEY is required) ----------------------
# Obtain from the Volcano Engine console: https://console.volcengine.com/speech/new
DOUBAO_API_KEY=$DOUBAO_API_KEY

# -- Legacy Console (all three fields are required) ----------------------------------
# DOUBAO_APP_KEY=$DOUBAO_APP_KEY       # Used by the voice cloning endpoint
# DOUBAO_APP_ID=$DOUBAO_APP_ID         # Used by the TTS synthesis endpoint
# DOUBAO_ACCESS_KEY=$DOUBAO_ACCESS_KEY # Shared by both endpoints
