# Nano Banana Image Generation - Environment Variables Configuration
# Copy this file to .env and fill in real values: cp .env.example .env

# Google Gemini API Key (required)
# Get it from Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY=$GEMINI_API_KEY
# HTTP/HTTPS proxy (optional)
# HTTPS_PROXY=$HTTPS_PROXY
# HTTP_PROXY=$HTTP_PROXY
